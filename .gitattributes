# Normalize line endings to LF on commit, checkout as OS-native
* text=auto eol=lf

# Ensure shell scripts always use LF
*.sh text eol=lf

# Ensure batch/VBS files use CRLF (Windows-only)
*.bat text eol=crlf
*.cmd text eol=crlf
*.vbs text eol=crlf
*.ps1 text eol=crlf

# Binary files
*.flac binary
*.wav binary
*.mp3 binary
*.png binary
*.ico binary
